# .env.shared — committed, propagates via git pull.
# Shared tuning knobs that should be identical across machines.
# Secrets and machine-specific values (API keys, DATABASE_URL, REDIS_URL,
# ALPACA credentials) live in .env (gitignored).
# Docker-specific overrides (container DATABASE_URL, REDIS_URL, log paths, TZ)
# stay in docker-compose.yml environment: — leave those alone.
#
# IMPORTANT: keep every comment on its own line *above* the variable.
# Docker Compose env_file does NOT strip inline `# ...` — FOO=bar  # note
# is loaded as the literal value `bar  # note`.

# ── LLM provider (change MODEL_TYPE to swap — zero code changes) ─────────────
MODEL_TYPE=groq
MODEL_NAME=llama-3.3-70b-versatile
OLLAMA_MODEL=llama3.2
# "free" applies conservative RPM caps per provider; "paid" removes them
LLM_TIER=free

# ── Per-task LLM overrides (empty = falls back to MODEL_TYPE / MODEL_NAME) ───
# LangGraph ReAct loop — speed matters, use a fast/cheap model
LLM_AGENT_TYPE=
LLM_AGENT_MODEL=
# Tier 2 click-to-expand analysis panels — moderate quality
LLM_TIER2_TYPE=
LLM_TIER2_MODEL=
# Tier 3 deep on-demand tools — investor personas, bull/bear, earnings transcript
LLM_TIER3_TYPE=
LLM_TIER3_MODEL=

# ── yfinance ──────────────────────────────────────────────────────────────────
# Lower = safer against Yahoo 429s (especially in Docker)
YF_REQUESTS_PER_SECOND=2.0

# ── Data source config (not secrets) ─────────────────────────────────────────
REDDIT_USER_AGENT=StockResearchPro/1.0

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
# Path to the rolling usage JSON — relative to the process working directory
USAGE_FILE=./data/usage.json

# ── Background jobs ───────────────────────────────────────────────────────────
SCREENER_INTERVAL_MINUTES=15
WATCHLIST_ALERT_INTERVAL_MINUTES=5

# ── Broker — paper trading first, live after sign-off ─────────────────────────
# See docs/trading.md SEC:PHASES + SEC:RISK. Live is not on the roadmap.
BROKER=alpaca
# paper | live — rotating mode without rotating Alpaca keys returns 403
BROKER_MODE=paper

# ── Trade risk caps (server-side, non-bypassable) ─────────────────────────────
TRADE_MAX_ORDER_DOLLARS=2000
TRADE_MAX_POSITION_DOLLARS=5000
TRADE_DAILY_LOSS_CAP_DOLLARS=-200
# Max orders per day (manual + auto combined). 51st is rejected with 422.
TRADE_DAILY_ORDER_COUNT_CAP=50

# ── Auto-trade (Phase 3 — paper validation, gated by flag + allowlist) ─────────
# Turn on to let the subscriber convert scanner_alerts into bracket paper orders.
AUTO_TRADE_ENABLED=false
# Comma-separated allowlist, e.g. failed_breakdown,mcf_dip_buy. Empty = nothing fires.
AUTO_TRADE_SIGNAL_TYPES=
# Subscriber poll interval in seconds (30 s → scanner-alert → submit < 1 min)
AUTO_TRADE_POLL_SECONDS=30

# ── Scanner ───────────────────────────────────────────────────────────────────
# Dip + MCF scanners halt for the day once today's scanner_alert count hits this
SCANNER_DAILY_SIGNAL_CAP=50
# Live score gate — signal must score >= this to fire and to be persisted.
# Backfill uses the same value so live + historical stay aligned.
# Set to 70 to admit the near-miss band (65–71). Restart required, no rebuild.
SCANNER_SCORE_THRESHOLD=72

# ── Usage guard rails ─────────────────────────────────────────────────────────
TOKEN_DAILY_LIMIT=50000
TOKEN_WEEKLY_LIMIT=200000
TOKEN_MONTHLY_LIMIT=500000
API_CALLS_DAILY_LIMIT=500

# ── Cache TTLs — stock data (days) ────────────────────────────────────────────
# Fallback when next_earnings_date is unknown; normally expires dynamically
CACHE_TTL_EARNINGS_FALLBACK_DAYS=30
# P/E, margins, FCF — quarterly updates
CACHE_TTL_FUNDAMENTALS_DAYS=30
# Price targets shift weekly; refresh daily
CACHE_TTL_ANALYST_DAYS=1
# FINRA bi-weekly; 7 days is safe
CACHE_TTL_SHORT_INTEREST_DAYS=7
# Piotroski/Beneish/Altman — quarterly math
CACHE_TTL_EARNINGS_QUALITY_DAYS=30

# ── Cache TTLs — stock data (hours) ──────────────────────────────────────────
# 30 min — stale news causes bad signals
CACHE_TTL_NEWS_HOURS=0.5
# STOCK Act filings are sporadic
CACHE_TTL_CONGRESSIONAL_HOURS=24

# ── Cache TTLs — LLM results (hours) ─────────────────────────────────────────
# Intraday: convergence, sentiment, risk/reward, options_intelligence
CACHE_TTL_LLM_SHORT_HOURS=0.5
# General tier2 fallback
CACHE_TTL_LLM_TIER2_HOURS=2.0
# Daily re-analysis: price_forecast, bull/bear, cascade
CACHE_TTL_LLM_TIER3_HOURS=24
# 7 days — historical backtest results are stable
CACHE_TTL_LLM_BACKTEST_HOURS=168
# 7 days — investment thesis changes slowly
CACHE_TTL_LLM_PERSONAS_HOURS=168
