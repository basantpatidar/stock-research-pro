# .env.example — secrets + machine-specific values only.
# Copy this file to .env and fill in your credentials.
#
# Shared tuning knobs (MODEL_TYPE, all CACHE_TTL_*, TRADE_*, AUTO_TRADE_*,
# SCANNER_*, BROKER, BROKER_MODE, etc.) live in .env.shared (committed and
# propagates via git pull). Edit .env.shared for anything that should stay
# consistent across machines.
#
# IMPORTANT: keep every comment on its own line *above* the variable.
# Docker Compose env_file does NOT strip inline `# ...` — FOO=bar  # note
# is loaded as the literal value `bar  # note`.

# ── LLM API keys — only the key for the active MODEL_TYPE is required ─────────
# MODEL_TYPE is set in .env.shared. Supported values and matching model names:
#   groq       → GROQ_API_KEY,       MODEL_NAME: llama-3.3-70b-versatile
#   cerebras   → CEREBRAS_API_KEY,   MODEL_NAME: llama3.3-70b
#   openrouter → OPENROUTER_API_KEY, MODEL_NAME: meta-llama/llama-3.3-70b-instruct:free
#   gemini     → GEMINI_API_KEY,     MODEL_NAME: gemini-2.5-flash
#   openai     → OPENAI_API_KEY,     MODEL_NAME: gpt-4o-mini
#   claude     → ANTHROPIC_API_KEY,  MODEL_NAME: claude-sonnet-4-5
#   ollama     → no key needed,      set OLLAMA_MODEL in .env.shared
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Data source secrets ────────────────────────────────────────────────────────
# newsapi.org — free 100 req/day dev tier
NEWSAPI_KEY=
# fred.stlouisfed.org — free; enables /macro/fred credit/rates dashboard
FRED_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# ── App ────────────────────────────────────────────────────────────────────────
API_KEY=dev-secret-key-change-in-production
# Local (non-Docker) only — Docker Compose overrides these with container service names
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stockresearch
REDIS_URL=redis://localhost:6379

# ── Telegram bot ──────────────────────────────────────────────────────────────
# Create a bot via @BotFather in Telegram — takes ~2 min, completely free.
# Get your chat_id from @userinfobot after starting any chat with your bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Alpaca credentials ─────────────────────────────────────────────────────────
# Paper and live use DIFFERENT keys on Alpaca — rotating BROKER_MODE in
# .env.shared without also rotating these keys here returns 403.
# Get paper keys: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_API_SECRET=
# Leave blank — alpaca-py auto-resolves to paper/live URL from BROKER_MODE.
# Do NOT include /v2 — the SDK appends it (a value of `.../v2` produces `/v2/v2/orders`).
ALPACA_BASE_URL=
