# ── Provider selection ──────────────────────────────────────────────────────
# model_type options:
#   ollama     — local Ollama (free, no key)         → set ollama_model below
#   gemini     — Google Gemini API (GEMINI_API_KEY)  → model_name: gemini-2.5-flash
#   openai     — OpenAI API (OPENAI_API_KEY)         → model_name: gpt-4o-mini
#   groq       — Groq free tier (GROQ_API_KEY)       → model_name: llama-3.3-70b-versatile
#   cerebras   — Cerebras free tier (CEREBRAS_API_KEY) → model_name: llama3.3-70b
#   openrouter — OpenRouter free models (OPENROUTER_API_KEY) → model_name: meta-llama/llama-3.3-70b-instruct:free
#   claude     — Anthropic Claude (ANTHROPIC_API_KEY) → model_name: claude-sonnet-4-5
MODEL_TYPE=groq
MODEL_NAME=llama-3.3-70b-versatile
OLLAMA_MODEL=llama3.2

# ── LLM API keys — only the selected provider's key is required ─────────────
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Data sources ─────────────────────────────────────────────────────────────
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=StockResearchPro/1.0

# ── App ───────────────────────────────────────────────────────────────────────
API_KEY=dev-secret-key-change-in-production
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stockresearch
REDIS_URL=redis://localhost:6379
ENVIRONMENT=development
LOG_DIR=./local_debugging

# ── Screener ──────────────────────────────────────────────────────────────────
SCREENER_INTERVAL_MINUTES=15
WATCHLIST_ALERT_INTERVAL_MINUTES=5

# ── Broker (paper trading first, live after sign-off) ──────────────────────────
# See docs/trading.md SEC:PHASES for the rollout plan and SEC:RISK for the
# pre-live checklist before flipping BROKER_MODE=live.
# Paper and live use DIFFERENT keys on Alpaca — rotating BROKER_MODE without
# also rotating the keys returns 403.
BROKER=alpaca                  # alpaca (only supported provider for now)
BROKER_MODE=paper              # paper | live
ALPACA_API_KEY=                # get from https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_SECRET=
ALPACA_BASE_URL=               # optional override; auto-resolved from BROKER_MODE if blank

# ── Trading risk caps (server-side, non-bypassable) ────────────────────────────
TRADE_MAX_ORDER_DOLLARS=2000
TRADE_MAX_POSITION_DOLLARS=5000
TRADE_DAILY_LOSS_CAP_DOLLARS=-200
TRADE_DAILY_ORDER_COUNT_CAP=20

# ── Auto-trade (off until Phase 3 sign-off) ────────────────────────────────────
AUTO_TRADE_ENABLED=false
AUTO_TRADE_SIGNAL_TYPES=       # comma-separated allowlist; empty = none

# ── Cache TTLs ────────────────────────────────────────────────────────────────
# Stock data cache — days (quarterly / slow-changing data)
CACHE_TTL_EARNINGS_FALLBACK_DAYS=30   # fallback when next_earnings_date unknown; normally expires dynamically
CACHE_TTL_FUNDAMENTALS_DAYS=30        # P/E, margins, FCF — quarterly updates
CACHE_TTL_ANALYST_DAYS=1              # price targets shift weekly; refresh daily
CACHE_TTL_SHORT_INTEREST_DAYS=7       # FINRA bi-weekly; 7 days is safe
CACHE_TTL_EARNINGS_QUALITY_DAYS=30    # Piotroski/Beneish/Altman — quarterly math
# Stock data cache — hours
CACHE_TTL_NEWS_HOURS=0.5              # 30 min — stale news causes bad signals
CACHE_TTL_CONGRESSIONAL_HOURS=24      # STOCK Act filings are sporadic
# LLM result cache — hours
CACHE_TTL_LLM_SHORT_HOURS=0.5        # 30 min — convergence, sentiment, risk/reward, options_intelligence
CACHE_TTL_LLM_TIER2_HOURS=2          # general tier2 fallback (news, etc.)
CACHE_TTL_LLM_TIER3_HOURS=24         # daily re-analysis: price_forecast, bull/bear, cascade
CACHE_TTL_LLM_BACKTEST_HOURS=168     # 7 days — historical backtest results are stable
CACHE_TTL_LLM_PERSONAS_HOURS=168     # 7 days — investment thesis changes slowly
