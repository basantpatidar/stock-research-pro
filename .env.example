# ── Provider selection ──────────────────────────────────────────────────────
# model_type options:
#   ollama     — local Ollama (free, no key)         → set ollama_model below
#   gemini     — Google Gemini API (GEMINI_API_KEY)  → model_name: gemini-2.5-flash
#   openai     — OpenAI API (OPENAI_API_KEY)         → model_name: gpt-4o-mini
#   groq       — Groq free tier (GROQ_API_KEY)       → model_name: llama-3.3-70b-versatile
#   cerebras   — Cerebras free tier (CEREBRAS_API_KEY) → model_name: llama3.3-70b
#   openrouter — OpenRouter free models (OPENROUTER_API_KEY) → model_name: meta-llama/llama-3.3-70b-instruct:free
#   claude     — Anthropic Claude (ANTHROPIC_API_KEY) → model_name: claude-sonnet-4-5
MODEL_TYPE=groq
MODEL_NAME=llama-3.3-70b-versatile
OLLAMA_MODEL=llama3.2

# ── LLM API keys — only the selected provider's key is required ─────────────
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Data sources ─────────────────────────────────────────────────────────────
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=StockResearchPro/1.0

# ── App ───────────────────────────────────────────────────────────────────────
API_KEY=dev-secret-key-change-in-production
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stockresearch
REDIS_URL=redis://localhost:6379
ENVIRONMENT=development
LOG_DIR=./local_debugging

# ── Scanner diagnostics logs ───────────────────────────────────────────────────
# Append-only JSONL files the dip scanner writes: a heartbeat (proof each scan
# tick ran) and the near-miss log (signals scored 65-71). eod_dump.py folds both
# into the daily eod_signals JSON.
# Leave BLANK for local (non-Docker) runs — the code defaults to ./local_debugging/.
# docker-compose.yml sets these to /app/local_debugging/* so they land in the
# host-mounted volume. Do NOT put an absolute /app path here — it would break
# local runs that have no /app directory.
SCANNER_HEARTBEAT_LOG=
NEAR_MISS_LOG=

# ── Screener ──────────────────────────────────────────────────────────────────
SCREENER_INTERVAL_MINUTES=15
WATCHLIST_ALERT_INTERVAL_MINUTES=5

# ── Broker (paper trading first, live after sign-off) ──────────────────────────
# See docs/trading.md SEC:PHASES for the rollout plan and SEC:RISK for the
# pre-live checklist before flipping BROKER_MODE=live.
# Paper and live use DIFFERENT keys on Alpaca — rotating BROKER_MODE without
# also rotating the keys returns 403.
#
# IMPORTANT: keep comments on their own line *above* the variable. Docker
# Compose's env_file parser does NOT strip inline `# ...` after a value, so
# `FOO=bar   # note` will be loaded as the literal value `bar   # note`.

# BROKER: alpaca (only supported provider for now)
BROKER=alpaca
# BROKER_MODE: paper | live
BROKER_MODE=paper
# ALPACA_API_KEY: get from https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=
ALPACA_API_SECRET=
# ALPACA_BASE_URL: leave blank — alpaca-py auto-resolves to the paper/live URL
# from BROKER_MODE. Only override for sandbox testing. Do NOT include /v2 —
# the SDK appends it (a value of `.../v2` produces `/v2/v2/orders`).
ALPACA_BASE_URL=

# ── Trading risk caps (server-side, non-bypassable) ────────────────────────────
TRADE_MAX_ORDER_DOLLARS=2000
TRADE_MAX_POSITION_DOLLARS=5000
TRADE_DAILY_LOSS_CAP_DOLLARS=-200
# Max orders per day (manual + auto combined). 51st is rejected with 422.
TRADE_DAILY_ORDER_COUNT_CAP=50

# ── Auto-trade (Phase 3 — paper validation, gated by flag + allowlist) ─────────
# Turn on to let the auto-trade subscriber convert scanner_alert rows into
# paper bracket orders. Manual orders keep working regardless.
AUTO_TRADE_ENABLED=false
# AUTO_TRADE_SIGNAL_TYPES: comma-separated allowlist of scanner signal_type
# values. Empty = nothing fires even if AUTO_TRADE_ENABLED=true. Example:
#   AUTO_TRADE_SIGNAL_TYPES=failed_breakdown,mcf_dip_buy
AUTO_TRADE_SIGNAL_TYPES=
# Subscriber poll interval (seconds). 30s = scanner-alert → submit < 1 min.
AUTO_TRADE_POLL_SECONDS=30
# Scanner halt — once today's scanner_alert count hits this, the dip + MCF
# scanners stop for the day. Default matches TRADE_DAILY_ORDER_COUNT_CAP.
SCANNER_DAILY_SIGNAL_CAP=50
# Live score gate for the dip scanner — a signal must score >= this to fire and
# to be persisted (backfill uses the same value). Default 72. Set to 70 to admit
# the near-miss band (65-71). Env-only + restart, no rebuild; revert the same way.
SCANNER_SCORE_THRESHOLD=72

# ── Cache TTLs ────────────────────────────────────────────────────────────────
# Stock data cache — days (quarterly / slow-changing data)
# fallback when next_earnings_date unknown; normally expires dynamically
CACHE_TTL_EARNINGS_FALLBACK_DAYS=30
# P/E, margins, FCF — quarterly updates
CACHE_TTL_FUNDAMENTALS_DAYS=30
# price targets shift weekly; refresh daily
CACHE_TTL_ANALYST_DAYS=1
# FINRA bi-weekly; 7 days is safe
CACHE_TTL_SHORT_INTEREST_DAYS=7
# Piotroski/Beneish/Altman — quarterly math
CACHE_TTL_EARNINGS_QUALITY_DAYS=30

# Stock data cache — hours
# 30 min — stale news causes bad signals
CACHE_TTL_NEWS_HOURS=0.5
# STOCK Act filings are sporadic
CACHE_TTL_CONGRESSIONAL_HOURS=24

# LLM result cache — hours
# 30 min — convergence, sentiment, risk/reward, options_intelligence
CACHE_TTL_LLM_SHORT_HOURS=0.5
# general tier2 fallback (news, etc.)
CACHE_TTL_LLM_TIER2_HOURS=2
# daily re-analysis: price_forecast, bull/bear, cascade
CACHE_TTL_LLM_TIER3_HOURS=24
# 7 days — historical backtest results are stable
CACHE_TTL_LLM_BACKTEST_HOURS=168
# 7 days — investment thesis changes slowly
CACHE_TTL_LLM_PERSONAS_HOURS=168
