# ── Provider selection ──────────────────────────────────────────────────────
# model_type options:
#   ollama     — local Ollama (free, no key)         → set ollama_model below
#   gemini     — Google Gemini API (GEMINI_API_KEY)  → model_name: gemini-2.5-flash
#   openai     — OpenAI API (OPENAI_API_KEY)         → model_name: gpt-4o-mini
#   groq       — Groq free tier (GROQ_API_KEY)       → model_name: llama-3.3-70b-versatile
#   cerebras   — Cerebras free tier (CEREBRAS_API_KEY) → model_name: llama3.3-70b
#   openrouter — OpenRouter free models (OPENROUTER_API_KEY) → model_name: meta-llama/llama-3.3-70b-instruct:free
#   claude     — Anthropic Claude (ANTHROPIC_API_KEY) → model_name: claude-sonnet-4-5
MODEL_TYPE=groq
MODEL_NAME=llama-3.3-70b-versatile
OLLAMA_MODEL=llama3.2

# ── LLM API keys — only the selected provider's key is required ─────────────
GROQ_API_KEY=
CEREBRAS_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Data sources ─────────────────────────────────────────────────────────────
NEWSAPI_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=StockResearchPro/1.0

# ── App ───────────────────────────────────────────────────────────────────────
API_KEY=dev-secret-key-change-in-production
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/stockresearch
REDIS_URL=redis://localhost:6379
ENVIRONMENT=development

# ── Screener ──────────────────────────────────────────────────────────────────
SCREENER_INTERVAL_MINUTES=15
WATCHLIST_ALERT_INTERVAL_MINUTES=5
